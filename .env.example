# Copy to .env and fill in. Never commit your real .env.

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Use a free serverless Postgres: Neon (https://neon.tech) or Vercel Postgres.
# On Vercel, add the Postgres integration and this is set for you.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ── Authentication (Clerk) ──────────────────────────────────────────────────
# Free at https://clerk.com — create an application and copy its API keys.
# If these are left unset the app still runs in anonymous "guest" mode
# (progress is kept only in the browser's localStorage).
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="<your-clerk-publishable-key>"
CLERK_SECRET_KEY="<your-clerk-secret-key>"

# ── Site URL (SEO / Open Graph) ─────────────────────────────────────────────
# Your production domain, used for canonical + social-share links.
# On Vercel this can be left unset (the per-deploy VERCEL_URL is used as a
# fallback), but set it to your real domain for stable share previews.
NEXT_PUBLIC_APP_URL="https://your-app.vercel.app"
</content>
